{
  "$schema": "https://schemas.tauri.app/v2/capabilities",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "shell:default",
    "clipboard-manager:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "shell:allow-execute",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text"
  ]
}
