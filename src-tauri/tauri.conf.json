{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LightOfficeTools",
  "version": "1.0.0",
  "identifier": "com.lightoffice.tools",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "轻量化办公文档工具箱",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "轻量化办公文档工具箱",
    "longDescription": "完全离线、秒开即用，聚焦办公文档场景的高效工具集",
    "publisher": "LightOfficeTools"
  }
}
